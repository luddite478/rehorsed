{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Library Item Schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "integer",
      "enum": [1]
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "local_path": {
      "type": "string",
      "description": "Required local file path"
    },
    "format": {
      "type": "string",
      "enum": ["mp3", "wav"]
    },
    "duration": {
      "type": "number"
    },
    "size_bytes": {
      "type": "integer"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "schema_version",
    "id",
    "name",
    "local_path",
    "format",
    "created_at"
  ],
  "additionalProperties": false
}
