{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Checkpoint Schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "integer",
      "enum": [1]
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "pattern_id": {
      "type": "string",
      "format": "uuid"
    },
    "snapshot": {
      "type": "object",
      "additionalProperties": true
    },
    "snapshot_metadata": {
      "type": "object",
      "properties": {
        "sections_count": {
          "type": "integer"
        },
        "sections_steps": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "sections_loops_num": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        },
        "layers": {
          "type": "array",
          "items": {
            "type": "integer"
          }
        }
      }
    },
    "audio_file_path": {
      "type": "string",
      "description": "Local file path for recorded audio"
    },
    "audio_duration": {
      "type": "number"
    }
  },
  "required": [
    "schema_version",
    "id",
    "created_at",
    "pattern_id",
    "snapshot"
  ],
  "additionalProperties": false
}
