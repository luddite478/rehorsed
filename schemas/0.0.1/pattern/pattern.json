{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Pattern Schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "integer",
      "enum": [1]
    },
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "UUID for local identification"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "checkpoint_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uuid"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "schema_version",
    "id",
    "name",
    "created_at",
    "updated_at",
    "checkpoint_ids"
  ],
  "additionalProperties": false
}
